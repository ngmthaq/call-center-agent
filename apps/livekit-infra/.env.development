# =============================================================================
# Development Environment Variables
#
# This file is SAFE TO COMMIT to version control.
# It contains development-only placeholder values — no real secrets.
# All values here are intentionally generic and publicly known dev defaults.
# Never copy these values into a production environment.
# =============================================================================

# LiveKit API credentials — must match the keys: section in livekit.development.yaml
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# PostgreSQL credentials for the call-center-agent application database
POSTGRES_DB=callcenter_dev
POSTGRES_USER=callcenter
POSTGRES_PASSWORD=callcenter_dev_password

# Redis app port — different from redis-livekit (6379) to avoid host port conflict
REDIS_APP_PORT=6380
